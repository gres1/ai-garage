{
  "name": "ai-garage",
  "version": "0.1.0",
  "description": "AI Garage — visual control panel for your localhost services, ports and tunnels — no terminal. See and stop everything running (even what AI agents left behind), free a stuck port, share a public link, on Mac and VPS.",
  "type": "module",
  "bin": {
    "ai-garage": "server.mjs",
    "ai-garage-mcp": "mcp.mjs"
  },
  "mcpName": "io.github.gres1/ai-garage",
  "scripts": {
    "start": "node server.mjs"
  },
  "files": [
    "server.mjs",
    "mcp.mjs",
    "public/",
    "README.md",
    "AGENTS.md",
    "LICENSE"
  ],
  "keywords": [
    "localhost",
    "ports",
    "tunnel",
    "cloudflared",
    "process-manager",
    "kill-port",
    "ai-agents",
    "ai-agent",
    "claude-code",
    "cursor",
    "developer-tools",
    "devtools",
    "dx",
    "zero-dependencies",
    "macos",
    "dashboard"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gres1/ai-garage.git"
  },
  "homepage": "https://github.com/gres1/ai-garage#readme",
  "bugs": {
    "url": "https://github.com/gres1/ai-garage/issues"
  },
  "license": "MIT",
  "author": "Az (@figga1)"
}
